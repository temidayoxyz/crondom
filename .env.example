# Turso database URL and token for browser-based access
# Get these from `turso db show --url <db-name>` and `turso db create-token <db-name>`
# WARNING: The token is embedded in the frontend build.
# For an MVP this is acceptable — Turso tokens can be scoped to specific operations.
VITE_TURSO_DATABASE_URL=libsql://your-db.turso.io
VITE_TURSO_AUTH_TOKEN=your-read-write-token
